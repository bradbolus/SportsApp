# ─── MATCHDAY ENVIRONMENT VARIABLES ─────────────────────────────
#
# Copy this file to .env and fill in your keys.
# The .env file is in .gitignore — it will NEVER be committed to GitHub.
#
# cp .env.example .env

# ─── THE ODDS API ─────────────────────────────────────────────────
# Free tier: 500 requests/month, no credit card required
# Sign up at: https://the-odds-api.com/
# Free tier is plenty for personal use.
ODDS_API_KEY=paste_your_key_here

# ─── SERVER ───────────────────────────────────────────────────────
# Port to run the local server on (default: 3000)
# PORT=3000

# ─── FUTURE KEYS (not needed yet) ────────────────────────────────
# TheSportsDB Premium (optional — free tier works fine without this)
# TSDB_API_KEY=

# API-Sports (optional future integration)
# API_SPORTS_KEY=
